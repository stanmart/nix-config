{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "qc-claude-login",
	  "model": "eu.anthropic.claude-opus-4-6-v1",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_CONFIG_FILE": "/Users/stanmart/.claude/aws.config",
    "AWS_PROFILE": "stanmart",
    "AWS_REGION": "eu-central-1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "enableWeakerNetworkIsolation": true,
    "network": {
	    "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    },
    "filesystem": {
	    "allowWrite": ["//tmp/claude/**", "//private/tmp/claude/**"]
    },
    "excludedCommands": [
      "git *",
      "gh *"
    ]
  },
  "permissions": {
    "allow": [
      "Edit(./**)",
      "Read(./**)",
      "WebFetch",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git blame*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git commit*)",
      "Bash(git cherry-pick*)",
      "Bash(pixi lock)",
      "Bash(pixi install*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr status*)",
      "Bash(gh pr reviews*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue status*)",
      "mcp__ide__getDiagnostics"
    ]
  }
}